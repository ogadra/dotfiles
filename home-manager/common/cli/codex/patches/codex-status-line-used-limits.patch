diff --git a/tui/src/chatwidget/status_controls.rs b/tui/src/chatwidget/status_controls.rs
index d4de738..3ea1212 100644
--- a/tui/src/chatwidget/status_controls.rs
+++ b/tui/src/chatwidget/status_controls.rs
@@ -7,0 +8,17 @@ use super::*;
+use std::process::Command;
+use std::sync::Mutex;
+use std::sync::OnceLock;
+use std::time::Duration;
+use std::time::Instant;
+
+use chrono::Local;
+use serde_json::Value;
+
+const CODEX_COST_CACHE_TTL: Duration = Duration::from_secs(60);
+static CODEX_COST_CACHE: OnceLock<Mutex<Option<CodexCostCache>>> = OnceLock::new();
+
+#[derive(Debug, Clone)]
+struct CodexCostCache {
+    updated_at: Instant,
+    value: Option<String>,
+}
@@ -383,0 +401,27 @@ impl ChatWidget {
+    pub(super) fn status_line_limit_used_display(
+        &self,
+        window: Option<&RateLimitWindowDisplay>,
+        label: &str,
+    ) -> Option<String> {
+        let window = window?;
+        let used = window.used_percent.clamp(0.0f64, 100.0f64);
+        Some(format!("{label} {used:.0}% used"))
+    }
+
+    pub(super) fn status_line_codex_cost_display(&self) -> Option<String> {
+        let cache = CODEX_COST_CACHE.get_or_init(|| Mutex::new(None));
+        let mut cache = cache.lock().ok()?;
+        if let Some(cached) = cache.as_ref()
+            && cached.updated_at.elapsed() < CODEX_COST_CACHE_TTL
+        {
+            return cached.value.clone();
+        }
+
+        let value = load_codex_cost_display();
+        *cache = Some(CodexCostCache {
+            updated_at: Instant::now(),
+            value: value.clone(),
+        });
+        value
+    }
+
@@ -392,0 +437,48 @@ impl ChatWidget {
+
+fn load_codex_cost_display() -> Option<String> {
+    let today = Local::now().format("%Y%m%d").to_string();
+    let month = Local::now().format("%Y-%m").to_string();
+
+    let today_cost = ccusage_cost(&["codex", "daily", "--since", &today, "--until", &today]);
+    let month_cost = ccusage_month_cost(&month);
+
+    let mut parts = Vec::new();
+    if let Some(cost) = today_cost {
+        parts.push(format!("${cost:.2} today"));
+    }
+    if let Some(cost) = month_cost {
+        parts.push(format!("${cost:.2} month"));
+    }
+    (!parts.is_empty()).then(|| parts.join(" / "))
+}
+
+fn ccusage_month_cost(month: &str) -> Option<f64> {
+    let json = ccusage_json(&["codex", "monthly"])?;
+    json.get("monthly")?
+        .as_array()?
+        .iter()
+        .find(|row| row.get("month").and_then(Value::as_str) == Some(month))
+        .and_then(|row| row.get("costUSD"))
+        .and_then(Value::as_f64)
+        .filter(|cost| cost.is_finite() && *cost >= 0.0)
+}
+
+fn ccusage_cost(args: &[&str]) -> Option<f64> {
+    let json = ccusage_json(args)?;
+    json.get("totals")?
+        .get("costUSD")
+        .and_then(Value::as_f64)
+        .filter(|cost| cost.is_finite() && *cost >= 0.0)
+}
+
+fn ccusage_json(args: &[&str]) -> Option<Value> {
+    let output = Command::new("ccusage")
+        .args(args)
+        .args(["--offline", "--json"])
+        .output()
+        .ok()?;
+    if !output.status.success() {
+        return None;
+    }
+    serde_json::from_slice(&output.stdout).ok()
+}
