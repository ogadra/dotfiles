{ ... }:
{
  system.defaults.universalaccess = {
    # カーソルサイズ倍率 1.0〜4.0
    mouseDriverCursorSize = 1.0;

    # 画面切替等のアニメーションを軽減
    reduceMotion = true;

    # メニューバーやサイドバー等の透過効果を無効化
    reduceTransparency = true;

    # Ctrl+スクロールでズーム
    closeViewScrollWheelToggle = false;

    # ズーム時にキーボードフォーカスを追従
    closeViewZoomFollowsFocus = false;
  };
}
