{ ... }:
{
  system.defaults.dock = {

    # Dockを自動的に隠す
    autohide = true;

    # Dock表示までの遅延秒数
    autohide-delay = 3600.0;

    # アプリ起動時のバウンスアニメーション
    launchanim = false;

    # ウィンドウ最小化エフェクト "genie" | "scale"
    mineffect = "scale";

    # 最近使ったSpaceの使用順自動並替
    mru-spaces = false;

    # Dockアイコンサイズ
    tilesize = 1;

    # 起動中アプリのインジケータを表示するか
    show-process-indicators = false;

    # 最近使ったアプリをDockに表示
    show-recents = false;
  };
}
